            "mime": "application/json"
          }
        },
        {
          "targets": ["all"],
          "request": {
            "method": "POST",
            "path": "/{{index}}/_create/my_id",
            "body": "{ \"@timestamp\": \"2099-11-15T13:12:00\", \"message\": \"GET /search HTTP/1.1 200 1070000\", \"user\": { \"id\": \"kimchy\" } }",
            "mime": "application/json"
          }
        },
        {
          "targets": ["local"],
          "request": {
            "method": "PUT",
            "path": "/_test/v1/_process_work",
            "body": "",
            "mime": "text/plain"
          }
        },
        {
          "targets": ["external"],
          "request": {
            "method": "POST",
            "path": "/{{index}}/_refresh",
            "body": "",
            "mime": "application/json"
          }
        }
      ],
      "request": {
        "method": "POST",
        "path": "/{{index}}/_create/my_id",
        "body": "{ \"@timestamp\": \"2099-11-15T13:12:00\", \"message\": \"GET /search HTTP/1.1 200 1070000\", \"user\": { \"id\": \"kimchy\" } }",
        "mime": "application/json"
      },
      "assertions": [
        { "kind": "status", "value": 409 }
      ]
    },
